#!/bin/bash
# Claude Code hook dispatcher for the Clawd pet daemon.
#
# Usage in ~/.claude/settings.json (or .claude/settings.json in a project):
#
#   {
#     "hooks": {
#       "UserPromptSubmit": [{"hooks": [{"type": "command", "command": "<path>/clawd-hook prompt"}]}],
#       "PreToolUse":       [{"hooks": [{"type": "command", "command": "<path>/clawd-hook pre-tool"}]}],
#       "PostToolUse":      [{"hooks": [{"type": "command", "command": "<path>/clawd-hook post-tool"}]}],
#       "Notification":     [{"hooks": [{"type": "command", "command": "<path>/clawd-hook alert"}]}],
#       "Stop":             [{"hooks": [{"type": "command", "command": "<path>/clawd-hook stop"}]}]
#     }
#   }
#
# Hooks receive the full hook payload as JSON on stdin. We read enough to get the
# tool_name (for PreToolUse) and pass it as a note to the daemon.
#
# All requests are fire-and-forget with a tiny timeout so they never block Claude.

set -u
DAEMON_URL="${CLAWD_DAEMON_URL:-http://127.0.0.1:7878}"
TIMEOUT="${CLAWD_TIMEOUT:-0.4}"

action="${1:-}"
shift || true

post_state() {
    local state="$1"
    local note="${2:-}"
    local body
    if [ -n "$note" ]; then
        # naive but safe-enough escaping: strip quotes and limit length
        note_safe=$(printf '%s' "$note" | tr -d '"\\' | cut -c1-40)
        body=$(printf '{"state":"%s","note":"%s"}' "$state" "$note_safe")
    else
        body=$(printf '{"state":"%s"}' "$state")
    fi
    curl -s --max-time "$TIMEOUT" -XPOST -H 'Content-Type: application/json' \
        -d "$body" "$DAEMON_URL/state" >/dev/null 2>&1 || true
}

# Read stdin JSON (if any) without failing when no input is provided.
stdin_json=""
if [ ! -t 0 ]; then
    stdin_json=$(cat 2>/dev/null || true)
fi

# Extract a JSON string field via python (avoids jq dependency).
json_field() {
    local field="$1"
    [ -z "$stdin_json" ] && return
    printf '%s' "$stdin_json" | python3 -c "
import json, sys
try:
    obj = json.loads(sys.stdin.read())
    val = obj.get('$field', '') or obj.get('tool_input', {}).get('$field', '') or ''
    print(val if isinstance(val, str) else json.dumps(val)[:40])
except Exception:
    pass
" 2>/dev/null
}

case "$action" in
    prompt)
        post_state thinking "$(json_field session_id)"
        ;;
    pre-tool)
        tool=$(json_field tool_name)
        post_state tool_use "${tool:-tool}"
        ;;
    post-tool)
        # Quick beat back to thinking; daemon auto-falls to idle after timeout
        post_state thinking "$(json_field tool_name)"
        ;;
    alert)
        post_state alert "$(json_field message)"
        ;;
    stop)
        post_state happy "done"
        ;;
    touch)
        curl -s --max-time "$TIMEOUT" -XPOST "$DAEMON_URL/touch" >/dev/null 2>&1 || true
        ;;
    *)
        echo "Usage: clawd-hook prompt|pre-tool|post-tool|alert|stop|touch" >&2
        exit 64
        ;;
esac

exit 0
