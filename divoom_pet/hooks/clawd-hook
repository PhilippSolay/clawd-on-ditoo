#!/bin/bash
# Claude Code hook dispatcher for the Clawd pet daemon.
#
# Usage in ~/.claude/settings.json (or .claude/settings.json in a project):
#
#   {
#     "hooks": {
#       "UserPromptSubmit": [{"hooks": [{"type": "command", "command": "<path>/clawd-hook prompt"}]}],
#       "PreToolUse":       [{"hooks": [{"type": "command", "command": "<path>/clawd-hook pre-tool"}]}],
#       "PostToolUse":      [{"hooks": [{"type": "command", "command": "<path>/clawd-hook post-tool"}]}],
#       "Notification":     [{"hooks": [{"type": "command", "command": "<path>/clawd-hook alert"}]}],
#       "Stop":             [{"hooks": [{"type": "command", "command": "<path>/clawd-hook stop"}]}],
#       "SubagentStop":     [{"hooks": [{"type": "command", "command": "<path>/clawd-hook subagent"}]}],
#       "SessionStart":     [{"hooks": [{"type": "command", "command": "<path>/clawd-hook session-start"}]}]
#     }
#   }
#
# Live content: post-tool detects TodoWrite and drives a real progress bar from the
# todo list; subagent ticks an "agents finished" tally badge; session-start resets it.
#
# Hooks receive the full hook payload as JSON on stdin. We read enough to get the
# tool_name (for PreToolUse) and pass it as a note to the daemon.
#
# All requests are fire-and-forget with a tiny timeout so they never block Claude.

set -u
DAEMON_URL="${CLAWD_DAEMON_URL:-http://127.0.0.1:7878}"
TIMEOUT="${CLAWD_TIMEOUT:-0.4}"

action="${1:-}"
shift || true

post_state() {
    local state="$1"
    local note="${2:-}"
    local body
    # Build the JSON body in python so quotes/unicode are escaped safely, and so we
    # can attach this session's id (set below) for the multi-session fleet bar.
    body=$(STATE="$state" NOTE="$note" SID="${session_id:-}" python3 -c '
import json, os
b = {"state": os.environ["STATE"]}
note = os.environ.get("NOTE", "")
if note:
    b["note"] = note[:40]
sid = os.environ.get("SID", "")
if sid:
    b["session_id"] = sid
print(json.dumps(b))' 2>/dev/null)
    [ -z "$body" ] && body=$(printf '{"state":"%s"}' "$state")
    curl -s --max-time "$TIMEOUT" -XPOST -H 'Content-Type: application/json' \
        -d "$body" "$DAEMON_URL/state" >/dev/null 2>&1 || true
}

# Fire a raw event at the live-content surface (progress / badge / banner / tally).
post_event() {
    curl -s --max-time "$TIMEOUT" -XPOST -H 'Content-Type: application/json' \
        -d "$1" "$DAEMON_URL/event" >/dev/null 2>&1 || true
}

# Derive a progress bar from a TodoWrite payload: completed / total todos.
post_todo_progress() {
    [ -z "$stdin_json" ] && return
    body=$(printf '%s' "$stdin_json" | python3 -c "
import json, sys
try:
    obj = json.loads(sys.stdin.read())
    todos = obj.get('tool_input', {}).get('todos', []) or []
    total = len(todos)
    done = sum(1 for t in todos if t.get('status') == 'completed')
    if total:
        print(json.dumps({'kind': 'progress', 'value': done / total, 'color': 'green'}))
except Exception:
    pass
" 2>/dev/null)
    [ -n "$body" ] && post_event "$body"
}

# Read stdin JSON (if any) without failing when no input is provided.
stdin_json=""
if [ ! -t 0 ]; then
    stdin_json=$(cat 2>/dev/null || true)
fi

# Extract a JSON string field via python (avoids jq dependency).
json_field() {
    local field="$1"
    [ -z "$stdin_json" ] && return
    printf '%s' "$stdin_json" | python3 -c "
import json, sys
try:
    obj = json.loads(sys.stdin.read())
    val = obj.get('$field', '') or obj.get('tool_input', {}).get('$field', '') or ''
    print(val if isinstance(val, str) else json.dumps(val)[:40])
except Exception:
    pass
" 2>/dev/null
}

# This session's id rides along on every /state post (drives the fleet bar).
session_id=$(json_field session_id)

case "$action" in
    prompt)
        # Active "working" look: Clawd at his laptop (the coding scene).
        post_state coding
        ;;
    pre-tool)
        # Keep the gear animation for actual tool calls.
        tool=$(json_field tool_name)
        post_state tool_use "${tool:-tool}"
        ;;
    post-tool)
        # Back to the coding scene between tools; daemon auto-falls to idle on timeout.
        tool=$(json_field tool_name)
        post_state coding "$tool"
        # TodoWrite drives a live progress bar from the todo list.
        [ "$tool" = "TodoWrite" ] && post_todo_progress
        ;;
    alert)
        post_state alert "$(json_field message)"
        ;;
    stop)
        post_state happy "done"
        post_event '{"kind":"progress","clear":true}'
        ;;
    subagent)
        # A subagent finished — tick the "agents home" tally badge.
        post_event '{"kind":"agent_done"}'
        ;;
    session-start)
        # New session: reset the tally + clear any stale progress bar.
        post_event '{"kind":"agents_reset"}'
        post_event '{"kind":"progress","clear":true}'
        ;;
    touch)
        curl -s --max-time "$TIMEOUT" -XPOST "$DAEMON_URL/touch" >/dev/null 2>&1 || true
        ;;
    *)
        echo "Usage: clawd-hook prompt|pre-tool|post-tool|alert|stop|subagent|session-start|touch" >&2
        exit 64
        ;;
esac

exit 0
