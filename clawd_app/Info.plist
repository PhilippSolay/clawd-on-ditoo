<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>local.divoompet.clawd-app</string>
    <key>CFBundleName</key>
    <string>Clawd</string>
    <key>CFBundleDisplayName</key>
    <string>Clawd</string>
    <key>CFBundleExecutable</key>
    <string>Clawd</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>
    <!-- Menu-bar only: no Dock icon, no main window. -->
    <key>LSUIElement</key>
    <true/>
    <!-- This app is the responsible launcher for the daemon + Swift helpers, so
         the Bluetooth / Microphone TCC prompts are attributed to it. -->
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>Clawd needs Bluetooth to drive your Divoom Ditoo's pixel display.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>Clawd listens for claps on your Mac's microphone to react and toggle sleep.</string>
</dict>
</plist>
